# ──────────────────────────────────────────────────────────────────
# Template Ouro — Triumph Tech Holding
# Copie para .env e preencha os valores reais
# NUNCA commite o .env — ele está no .gitignore
# ──────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# App
APP_NAME="Meu Projeto"
APP_URL=http://localhost:3000
GIT_COMMIT=local

# JWT (use um secret forte em produção — openssl rand -hex 64)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Quanta Flow / Evolution API (WhatsApp) — via Secret do projeto
EVOLUTION_BASE_URL=https://evolution.seuservidor.com
EVOLUTION_API_KEY=seu-api-key-aqui
EVOLUTION_INSTANCE=default

# SMTP — via Secret do projeto
SMTP_HOST=smtp.seuservidor.com
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com
SMTP_PASS=sua-senha-smtp
SMTP_FROM=noreply@seudominio.com

# Número para alertas de uptime (formato internacional)
ALERT_PHONE=+5511999999999
